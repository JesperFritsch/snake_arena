# ── version control ──────────────────────────────────────────
.git/
.gitignore

# ── Python ───────────────────────────────────────────────────
**/.venv/
venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.egg-info/
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/

# ── uv ───────────────────────────────────────────────────────
# Keep uv.lock! It must be in the context for `uv sync --frozen`.

# ── Postgres ─────────────────────────────────────────────────
pg-data/

# ── Node / frontend ──────────────────────────────────────────
# Do NOT ignore all of frontend/ — the API image's stage-1 build
# needs frontend/src to produce dist/. Only the heavy/regenerable
# parts. **/-prefixed so frontend/node_modules is caught (a bare
# `node_modules/` matches ONLY the repo root, not nested ones).
**/node_modules/
**/dist/
**/build/

# ── Editor / OS ──────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
*.swp

# ── Secrets / local config ───────────────────────────────────
.env
.env.*

# ── Logs and local artifacts ─────────────────────────────────
**/*.log
sim-artifacts/
**/*.run_proto

# ── Docker ───────────────────────────────────────────────────
Dockerfile*
*.dockerignore